import tkinter as tk



def siguente_opcion():
 ventana1.withdraw()
 ventana2.deiconify()

def volver_inicio():
 ventana2.withdraw()
 ventana1.deiconify()


ventana1 = tk.Tk()
ventana1.title("Santa Lucia")
ventana1.geometry("400x300")

registro = tk.Label(
 ventana1,
 text="Ingrese su nombre:",
 font=("Arial", 16)
)
registro.pack(pady=10)

ingreso = tk.Entry(
 ventana1,
 fg="#538DD0",
 font=("Arial", 16)
)
